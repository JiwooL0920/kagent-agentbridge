# Build stage
FROM golang:1.25-alpine AS builder

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o alertmanager-hook ./cmd/alertmanager-hook

# Runtime stage
FROM alpine:3

RUN apk add --no-cache ca-certificates

COPY --from=builder /build/alertmanager-hook /usr/local/bin/

ENTRYPOINT ["alertmanager-hook"]
